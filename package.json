{
  "name": "impactopool",
  "version": "1.0.0",
  "description": "Plataforma descentralizada de donaciones con gestión blockchain en Avalanche",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --config jest.config.js",
    "test:integration": "jest Tests/integration/ --runInBand",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run src/blockchain/scripts/deploy.js --network fuji"
  },
  "keywords": [
    "donaciones",
    "blockchain",
    "avalanche",
    "x402",
    "erc-8004"
  ],
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@x402/evm": "^2.7.0",
    "@x402/express": "^2.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.0",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.17",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
