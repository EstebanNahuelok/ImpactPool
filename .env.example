# ===========================================
# ImpactoPool - Variables de Entorno
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/impactopool

# JWT
JWT_SECRET=tu_jwt_secret_aqui
JWT_EXPIRES_IN=7d

# Avalanche Blockchain
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113
DEPLOYER_PRIVATE_KEY=tu_private_key_aqui
DEPLOYER_ADDRESS=tu_wallet_address_aqui

# Contract Addresses (se llenan después del deploy)
IMPACTOPOOL_CONTRACT_ADDRESS=
DONATION_VAULT_CONTRACT_ADDRESS=
AGENT_REGISTRY_CONTRACT_ADDRESS=
REPUTATION_REGISTRY_CONTRACT_ADDRESS=

# x402 Payment Protocol (Coinbase official)
X402_FACILITATOR_URL=https://facilitator.x402.org
X402_PAY_TO_ADDRESS=tu_wallet_address_aqui

# USDC Token Address (Fuji Testnet — or deploy MockUSDC)
USDC_TOKEN_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
